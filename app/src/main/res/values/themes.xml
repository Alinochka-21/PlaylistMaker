<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PlaylistMaker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/YP_White</item>
        <item name="colorPrimaryVariant">@color/YP_Light_Gray</item>
        <item name="colorOnPrimary">@color/YP_Text_Gray</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/YP_Black</item>
        <item name="colorSecondaryVariant">@color/YP_Light_Gray</item>
        <item name="colorOnSecondary">@color/YP_Text_Gray</item>
        <!-- Another. -->
        <item name="android:windowBackground">?attr/colorPrimary</item>
        <item name="colorControlActivated">@color/YP_Blue</item>

    </style>

    <style name="Theme.OnlyMainDisplay" parent="Base.Theme.PlaylistMaker">
        <item name="android:windowBackground">@color/YP_Blue</item>
        <item name="materialButtonStyle">@style/MaterialButtonStyleInMain</item>
    </style>

</resources>